{
    // Editor Settings
    "editor.detectIndentation": false,
    "editor.trimAutoWhitespace": true,
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,
    "files.trimFinalNewlines": true,
    "editor.codeActionsOnSave": {
        "source.fixAll": "explicit",
        "source.fixAll.eslint": "explicit"
    },

    // Prettier Settings
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "prettier.requireConfig": true,
    "prettier.useEditorConfig": true,

    // ESLint Settings
    "eslint.validate": ["javascript", "javascriptreact", "typescript", "typescriptreact"],
    "eslint.run": "onType",
    "eslint.format.enable": false,
    "eslint.lintTask.enable": true,
    "eslint.codeActionsOnSave.mode": "all",
    "eslint.workingDirectories": [{ "mode": "auto" }],

    // EditorConfig Support
    "editorconfig.generateAuto": false,

    // TypeScript Settings (namespaced — TS 5+ form)
    "js/ts.preferences.importModuleSpecifier": "relative",
    "js/ts.suggest.autoImports": true,
    "js/ts.updateImportsOnFileMove.enabled": "prompt",

    // File Explorer
    "files.exclude": {
        "**/node_modules": true,
        "**/dist": true,
        "**/coverage": true,
        "**/.eslintcache": true,
        "**/.turbo": true
        // "**/logs": true
    },

    // Terminal
    "terminal.integrated.defaultProfile.osx": "zsh",

    // Search
    "search.exclude": {
        "**/node_modules": true,
        "**/dist": true,
        "**/.eslintcache": true,
        "**/logs": true
    },

    // Git and Version Control
    "git.autofetch": true,
    "git.confirmSync": false,
    "git.enableSmartCommit": false, // Better to pick files to stage manually

    // Performance and UI
    "extensions.ignoreRecommendations": false,
    "workbench.editor.enablePreview": true,
    "workbench.editor.closeEmptyGroups": false,

    // IntelliSense and Suggestions
    "editor.suggest.insertMode": "replace",
    "editor.acceptSuggestionOnCommitCharacter": false,
    "editor.quickSuggestions": {
        "other": true,
        "comments": false,
        "strings": false
    },

    // Language-specific settings
    "[jsonc]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[markdown]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "files.trimTrailingWhitespace": false
    },
    "github-actions.use-enterprise": false,

    // Vitest configuration
    "vitest.shellType": "terminal",
    "vitest.disableWorkspaceWarning": true,

    // Copilot / Claude auto-approve pnpm in chat-tool terminal
    "chat.tools.terminal.autoApprove": {
        "pnpm": true
    },

    // Markdownlint configuration (mirrors .markdownlint.json for IDE squiggle parity)
    "markdownlint.config": {
        "MD007": { "indent": 4 },
        "MD013": false,
        "MD024": false,
        "MD030": false,
        "MD033": false,
        "MD040": false,
        "MD041": false,
        "MD036": false,
        "MD060": false
    }
}
