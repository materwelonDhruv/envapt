{
    "$schema": "https://raw.githubusercontent.com/denoland/deno/main/cli/schemas/config-file.v1.json",
    "name": "@materwelon/envapt",
    "version": "7.0.0",
    "exports": {
        ".": "./src/index.ts",
        "./legacy": "./src/legacy.ts"
    },
    "license": "Apache-2.0",
    "publish": {
        "include": [
            "src/**/*.ts",
            "README.md",
            "LICENSE",
            "NOTICE.md",
            "CHANGELOG.md"
        ]
    },
    "lint": {
        "rules": {
            "exclude": [
                "no-sloppy-imports"
            ]
        }
    },
    "unstable": [
        "sloppy-imports"
    ]
}
