{
    "name": "envapt",
    "type": "module",
    "version": "5.1.1",
    "description": "Type-safe environment variables for TypeScript. Zero-dependency typed reader with the same API on Node, Bun, Deno, Cloudflare Workers, and the browser; loads .env files on Node, Bun, and Deno. Decorators, converters, and Standard Schema (zod/valibot/arktype) validation.",
    "types": "./dist/node/index.d.mts",
    "exports": {
        ".": {
            "workerd": {
                "types": "./dist/workerd/index.d.mts",
                "default": "./dist/workerd/index.mjs"
            },
            "browser": {
                "types": "./dist/browser/index.d.mts",
                "default": "./dist/browser/index.mjs"
            },
            "node": {
                "import": {
                    "types": "./dist/node/index.d.mts",
                    "default": "./dist/node/index.mjs"
                },
                "require": {
                    "types": "./dist/node/index.d.cts",
                    "default": "./dist/node/index.cjs"
                }
            },
            "default": {
                "import": {
                    "types": "./dist/node/index.d.mts",
                    "default": "./dist/node/index.mjs"
                },
                "require": {
                    "types": "./dist/node/index.d.cts",
                    "default": "./dist/node/index.cjs"
                }
            }
        },
        "./workerd": {
            "types": "./dist/workerd/index.d.mts",
            "default": "./dist/workerd/index.mjs"
        },
        "./browser": {
            "types": "./dist/browser/index.d.mts",
            "default": "./dist/browser/index.mjs"
        },
        "./config": {
            "import": {
                "types": "./dist/node/config.d.mts",
                "default": "./dist/node/config.mjs"
            },
            "require": {
                "types": "./dist/node/config.d.cts",
                "default": "./dist/node/config.cjs"
            }
        }
    },
    "sideEffects": [
        "./dist/node/config.cjs",
        "./dist/node/config.mjs",
        "./dist/browser/index.mjs",
        "./dist/workerd/index.mjs"
    ],
    "files": [
        "dist",
        "NOTICE.md",
        "LICENSE",
        "README.md",
        "CHANGELOG.md"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/materwelonDhruv/envapt.git"
    },
    "homepage": "https://envapt.materwelon.dev",
    "scripts": {
        "clean": "rm -rf dist",
        "build": "pnpm run clean && tsdown",
        "build:verify": "pnpm tsx scripts/verify-no-node.ts",
        "dev": "tsc --watch",
        "lint": "eslint '{src,tests,scripts}/**/*.{ts,tsx}' --cache",
        "lint:fix": "eslint '{src,tests,scripts}/**/*.{ts,tsx}' --fix --cache",
        "fmt": "prettier --write '{src,tests,scripts}/**/*.{ts,tsx,json,md}' --cache",
        "fmt:check": "prettier --check '{src,tests,scripts}/**/*.{ts,tsx,json,md}' --cache",
        "fmt:all": "prettier --write .",
        "tc": "tsc --noEmit",
        "tsd": "tsd",
        "test": "vitest run",
        "test:watch": "vitest dev",
        "test:integration": "node tests/integration/run.mjs",
        "coverage": "pnpm run test --coverage",
        "cs": "changeset",
        "cs:publish": "changeset publish",
        "cs:status": "changeset status",
        "bump": "pnpm tsx ../../scripts/bump-jsr.ts",
        "release": "pnpm run cs:publish",
        "prepare": "husky",
        "prepublishOnly": "pnpm run clean && pnpm run build"
    },
    "keywords": [
        "env",
        ".env",
        "dotenv",
        "environment",
        "variables",
        "config",
        "configuration",
        "settings",
        "typescript",
        "type-safe",
        "deno",
        "bun",
        "cloudflare-workers",
        "workers",
        "browser",
        "zod",
        "valibot",
        "arktype",
        "validation",
        "decorator",
        "dotenv-alternative",
        "cross-runtime",
        "esm",
        "env-var"
    ],
    "author": "Dhruv <materwelondhruv@gmail.com>",
    "license": "Apache-2.0",
    "engines": {
        "node": ">=20.0.0",
        "bun": ">=1.3.0",
        "deno": ">=2.5.0"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "devDependencies": {
        "arktype": "^2.2.0",
        "expect-type": "^1.3.0",
        "valibot": "^1.4.1",
        "zod": "catalog:dev"
    }
}
