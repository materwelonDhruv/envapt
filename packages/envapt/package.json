{
    "name": "envapt",
    "type": "module",
    "version": "7.0.3",
    "description": "Type-safe config for TypeScript. Read typed values from any source, process.env, .env files, Cloudflare Workers bindings, browser bundles, or any object you supply. Zero runtime dependencies, one API across Node, Bun, Deno, Workers, and the browser. TC39 accessor decorators (legacy decorators at envapt/legacy), converters, and Standard Schema (zod/valibot/arktype) validation.",
    "types": "./dist/types/index.d.mts",
    "exports": {
        ".": {
            "workerd": {
                "types": "./dist/types/index.portable.d.mts",
                "default": "./dist/portable/index.mjs"
            },
            "edge-light": {
                "types": "./dist/types/index.portable.d.mts",
                "default": "./dist/portable/index.mjs"
            },
            "fastly": {
                "types": "./dist/types/index.portable.d.mts",
                "default": "./dist/portable/index.mjs"
            },
            "worker": {
                "types": "./dist/types/index.portable.d.mts",
                "default": "./dist/portable/index.mjs"
            },
            "browser": {
                "types": "./dist/types/index.portable.d.mts",
                "default": "./dist/portable/index.mjs"
            },
            "react-native": {
                "types": "./dist/types/index.portable.d.mts",
                "default": "./dist/portable/index.mjs"
            },
            "deno": {
                "import": {
                    "types": "./dist/types/index.d.mts",
                    "default": "./dist/node/index.mjs"
                },
                "require": {
                    "types": "./dist/types/index.d.mts",
                    "default": "./dist/node/index.cjs"
                }
            },
            "node": {
                "import": {
                    "types": "./dist/types/index.d.mts",
                    "default": "./dist/node/index.mjs"
                },
                "require": {
                    "types": "./dist/types/index.d.mts",
                    "default": "./dist/node/index.cjs"
                }
            },
            "default": {
                "import": {
                    "types": "./dist/types/index.d.mts",
                    "default": "./dist/node/index.mjs"
                },
                "require": {
                    "types": "./dist/types/index.d.mts",
                    "default": "./dist/node/index.cjs"
                }
            }
        },
        "./config": {
            "import": {
                "types": "./dist/types/config.d.mts",
                "default": "./dist/node/config.mjs"
            },
            "require": {
                "types": "./dist/types/config.d.mts",
                "default": "./dist/node/config.cjs"
            }
        },
        "./legacy": {
            "workerd": {
                "types": "./dist/types/legacy.d.mts",
                "default": "./dist/portable/legacy.mjs"
            },
            "edge-light": {
                "types": "./dist/types/legacy.d.mts",
                "default": "./dist/portable/legacy.mjs"
            },
            "fastly": {
                "types": "./dist/types/legacy.d.mts",
                "default": "./dist/portable/legacy.mjs"
            },
            "worker": {
                "types": "./dist/types/legacy.d.mts",
                "default": "./dist/portable/legacy.mjs"
            },
            "browser": {
                "types": "./dist/types/legacy.d.mts",
                "default": "./dist/portable/legacy.mjs"
            },
            "react-native": {
                "types": "./dist/types/legacy.d.mts",
                "default": "./dist/portable/legacy.mjs"
            },
            "deno": {
                "import": {
                    "types": "./dist/types/legacy.d.mts",
                    "default": "./dist/node/legacy.mjs"
                },
                "require": {
                    "types": "./dist/types/legacy.d.mts",
                    "default": "./dist/node/legacy.cjs"
                }
            },
            "node": {
                "import": {
                    "types": "./dist/types/legacy.d.mts",
                    "default": "./dist/node/legacy.mjs"
                },
                "require": {
                    "types": "./dist/types/legacy.d.mts",
                    "default": "./dist/node/legacy.cjs"
                }
            },
            "default": {
                "import": {
                    "types": "./dist/types/legacy.d.mts",
                    "default": "./dist/node/legacy.mjs"
                },
                "require": {
                    "types": "./dist/types/legacy.d.mts",
                    "default": "./dist/node/legacy.cjs"
                }
            }
        },
        "./package.json": "./package.json"
    },
    "sideEffects": [
        "./dist/node/config.cjs",
        "./dist/node/config.mjs"
    ],
    "files": [
        "dist/**/*.mjs",
        "dist/**/*.cjs",
        "dist/**/*.map",
        "dist/types",
        "NOTICE.md",
        "LICENSE",
        "README.md",
        "CHANGELOG.md"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/materwelonDhruv/envapt.git"
    },
    "homepage": "https://envapt.materwelon.dev",
    "scripts": {
        "clean": "rm -rf dist",
        "build": "pnpm run clean && tsdown",
        "build:verify": "pnpm tsx scripts/verify-no-node.ts",
        "dev": "tsc --watch",
        "lint": "eslint '{src,tests,scripts}/**/*.{ts,tsx,mjs,cjs}' --cache",
        "lint:fix": "eslint '{src,tests,scripts}/**/*.{ts,tsx,mjs,cjs}' --fix --cache",
        "fmt": "prettier --write '{src,tests,scripts}/**/*.{ts,tsx,json,md}' --cache",
        "fmt:check": "prettier --check '{src,tests,scripts}/**/*.{ts,tsx,json,md}' --cache",
        "fmt:all": "prettier --write .",
        "tc": "tsc --noEmit",
        "tsd": "tsd",
        "test": "vitest run",
        "test:watch": "vitest dev",
        "test:integration": "node tests/integration/run.mjs",
        "test:workers": "tsc --noEmit -p tests/workers/tsconfig.json && vitest run --config vitest.workers.config.ts",
        "test:browser": "tsc --noEmit -p tests/browser/tsconfig.json && vitest run --config vitest.browser.config.ts",
        "test:consumer-build": "node tests/consumer-build/run.mjs",
        "test:tree-shaking": "node tests/tree-shaking/run.mjs",
        "test:exports-dedup": "node tests/exports-dedup/run.mjs",
        "test:resolution-matrix": "node tests/resolution-matrix/run.mjs",
        "test:cjs-validity": "node tests/cjs-validity/run.mjs",
        "test:tsc-emit": "node tests/tsc-emit/run.mjs",
        "test:stage3-emit": "node tests/stage3-emit/run.mjs",
        "test:all": "node ../../scripts/test-all.mjs",
        "coverage": "pnpm run test --coverage",
        "cs": "changeset",
        "cs:publish": "changeset publish",
        "cs:status": "changeset status",
        "bump": "pnpm tsx ../../scripts/release/bump-jsr.ts",
        "release": "pnpm run cs:publish",
        "prepare": "husky",
        "prepublishOnly": "pnpm run clean && pnpm run build"
    },
    "keywords": [
        "env",
        ".env",
        "dotenv",
        "environment",
        "variables",
        "config",
        "configuration",
        "settings",
        "typescript",
        "type-safe",
        "deno",
        "bun",
        "cloudflare-workers",
        "workers",
        "browser",
        "zod",
        "valibot",
        "arktype",
        "validation",
        "decorator",
        "dotenv-alternative",
        "cross-runtime",
        "esm",
        "env-var"
    ],
    "author": "Dhruv <materwelondhruv@gmail.com>",
    "license": "Apache-2.0",
    "engines": {
        "node": ">=20.0.0",
        "bun": ">=1.3.0",
        "deno": ">=2.5.0"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "devDependencies": {
        "@cloudflare/vitest-pool-workers": "0.16.19",
        "@cloudflare/workers-types": "^4.20260623.1",
        "@vitest/browser": "4.1.9",
        "@vitest/browser-playwright": "4.1.9",
        "arktype": "^2.2.1",
        "esbuild": "^0.28.1",
        "playwright": "1.61.0",
        "valibot": "^1.4.1",
        "zod": "catalog:dev"
    }
}
