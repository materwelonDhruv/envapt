# dependencies
node_modules/

# debug
npm-debug.*

# local env files
.env

# allow committed test fixtures (cascade tests need real .env files to load)
!packages/envapt/tests/cascade-fixtures/**/.env

# typescript
*.tsbuildinfo

# misc
debugging/
**/.DS_Store

# Certs
certs/

# Ignore build output directories
dist/
build/

# Ignore IDE specific files
**/.idea
**/.vs

# .vscode/ is whitelisted: only the standard shared editor config files are tracked;
# everything else (planning docs, audits, scratch, personal notes) stays local in a private inner git repo.
# Add to the !.vscode/<file> list as new project-wide editor configs appear.
/.vscode/*
!/.vscode/extensions.json
!/.vscode/launch.json
!/.vscode/settings.json
!/.vscode/tasks.json

# Standard agent-output names at repo root (kept local)
TASKS.md
STATUS.json
PROGRESS.md

# Turborepo
.turbo/

# Package manager caches
.pnpm-store/
.yarn/
.npm/

# Ignore log files
*.log
logs/
Logs/

# ESLint cache
.eslintcache

# Ignore coverage reports
.nyc_output/
coverage/

# Ignore temporary files
*.tmp
*.swp

# Ignore OS generated files
Thumbs.db
.DS_Store

# Ignore Docker files
# **/Dockerfile*
# **/docker-compose*

# Ignore secrets
**/secrets.dev.yaml
**/values.dev.yaml

# Ignore miscellaneous project files
**/.project
**/.classpath
**/.settings
**/.toolstarget
**/*.*proj.user
**/*.dbmdl
**/*.jfm

# Turborepo
.turbo
