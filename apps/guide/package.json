{
    "name": "@envapt/guide",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "TWOSLASH=0 next dev",
        "dev:twoslash": "NODE_OPTIONS=--max-old-space-size=8192 next dev",
        "build": "fumadocs-mdx && NODE_OPTIONS=--max-old-space-size=8192 next build",
        "start": "pnpm dlx serve out",
        "deploy": "wrangler deploy",
        "deploy:preview": "wrangler versions upload",
        "postinstall": "fumadocs-mdx",
        "lint": "eslint . --cache",
        "lint:fix": "eslint . --fix --cache",
        "fmt": "prettier --write . --cache",
        "fmt:check": "prettier --check . --cache"
    },
    "dependencies": {
        "clsx": "^2.1.1",
        "envapt": "workspace:^",
        "fumadocs-core": "16.9.2",
        "fumadocs-ui": "16.9.2",
        "next": "16.2.6",
        "next-themes": "^0.4.6",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "tailwind-merge": "^3.6.0"
    },
    "devDependencies": {
        "@seedcord/eslint-config": "catalog:dev",
        "@tailwindcss/postcss": "4.3.0",
        "@types/mdx": "^2.0.14",
        "@types/node": "catalog:dev",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "eslint": "catalog:dev",
        "eslint-config-next": "^16.2.9",
        "eslint-plugin-better-tailwindcss": "^4.6.0",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-mdx": "^3.8.1",
        "eslint-plugin-react-compiler": "19.1.0-rc.2",
        "eslint-plugin-tailwind-canonical-classes": "^1.3.3",
        "fumadocs-mdx": "15.0.10",
        "fumadocs-twoslash": "3.2.0",
        "postcss": "8.5.6",
        "prettier": "catalog:dev",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "shiki": "4.1.0",
        "tailwindcss": "4.3.0",
        "twoslash": "0.3.8",
        "typescript": "catalog:dev",
        "wrangler": "^4.100.0",
        "zod": "catalog:dev"
    }
}
