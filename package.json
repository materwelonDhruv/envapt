{
    "name": "@envapt/envapt",
    "type": "module",
    "version": "0.0.0",
    "description": "The apt way to handle env (repository root)",
    "private": true,
    "homepage": "https://envapt.materwelon.dev",
    "scripts": {
        "build": "turbo build",
        "dev": "turbo dev",
        "lint": "turbo lint && eslint 'scripts/**/*.{ts,mjs,cjs}' --cache",
        "lint:fix": "turbo lint:fix && eslint 'scripts/**/*.{ts,mjs,cjs}' --fix --cache",
        "lint:md": "markdownlint-cli2",
        "lint:fix:md": "markdownlint-cli2 --fix",
        "knip": "knip",
        "react-doctor": "react-doctor --verbose",
        "fmt": "turbo fmt",
        "fmt:check": "turbo fmt:check",
        "tc": "turbo tc",
        "test": "turbo test",
        "coverage": "turbo coverage",
        "prePush": "pnpm tc && pnpm lint && pnpm lint:md && pnpm test",
        "lint-staged": "lint-staged",
        "clean": "turbo clean",
        "clean:node": "find . -name node_modules -type d -prune -exec rm -rf '{}' +",
        "turbo:rebuild": "turbo clean && turbo build",
        "turbo:prebuild": "turbo clean && turbo lint && turbo tc",
        "turbo:prune": "turbo prune",
        "turbo:graph": "turbo build --graph",
        "turbo:trace": "turbo build --trace",
        "prepare": "husky",
        "cs": "changeset",
        "cs:publish": "changeset publish",
        "cs:status": "changeset status",
        "release": "pnpm run build && pnpm run cs:publish",
        "release:version": "changeset version && pnpm tsx scripts/bump-jsr.ts",
        "prepublishOnly": "pnpm run clean && pnpm run build",
        "bump:deps:pkgs": "for dir in packages/*/; do echo \"Updating $dir...\"; (cd \"$dir\" && pnpm update --latest); done",
        "bump:deps:apps": "for dir in apps/*/; do echo \"Updating $dir...\"; (cd \"$dir\" && pnpm update --latest); done",
        "bump:deps:root": "pnpm update --latest",
        "bump:deps": "pnpm run bump:deps:pkgs && pnpm run bump:deps:apps && pnpm run bump:deps:root"
    },
    "devDependencies": {
        "@changesets/cli": "^2.31.0",
        "@commitlint/cli": "^21.0.2",
        "@commitlint/config-conventional": "^21.0.2",
        "@seedcord/eslint-config": "catalog:dev",
        "@seedcord/tsconfig": "^2.0.0",
        "@types/node": "catalog:dev",
        "@vitest/coverage-v8": "4.1.9",
        "eslint": "catalog:dev",
        "husky": "^9.1.7",
        "knip": "^6.16.1",
        "lint-staged": "^17.0.7",
        "markdownlint-cli2": "^0.22.1",
        "prettier": "catalog:dev",
        "react-doctor": "^0.5.4",
        "tsdown": "^0.22.2",
        "tsx": "^4.22.4",
        "turbo": "^2.9.18",
        "typescript": "catalog:dev",
        "vite": "^8.0.16",
        "vitest": "4.1.9"
    },
    "packageManager": "pnpm@11.5.0"
}
